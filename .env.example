# ============================================
# TikTok Stock Sync - Variáveis de Ambiente
# ============================================

# ============================================
# DATABASE
# ============================================
DATABASE_URL=mysql://user:password@localhost:3306/tiktok_stock_sync

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=seu-secret-super-seguro-aqui-123456789
VITE_APP_ID=seu-app-id-manus
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im

# ============================================
# OWNER INFORMATION
# ============================================
OWNER_OPEN_ID=seu-owner-id-manus
OWNER_NAME=Guilherme Gomes

# ============================================
# MANUS API
# ============================================
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=sua-chave-api-manus-aqui
VITE_FRONTEND_FORGE_API_KEY=sua-chave-frontend-manus-aqui
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im

# ============================================
# ANALYTICS
# ============================================
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# ============================================
# APP BRANDING
# ============================================
VITE_APP_TITLE=TikTok Stock Sync
VITE_APP_LOGO=https://example.com/logo.png

# ============================================
# NODE.JS
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# INSTRUÇÕES
# ============================================
# 1. Copie este arquivo para .env.local
# 2. Preencha todos os valores
